<http://vocab.geospecimens.org/def/hazard-type> a skos:ConceptScheme;
    skos:prefLabel "Hazard Types"@en;
    dcterms:title "Hazard Types"@en;
    skos:definition "The Hazard Type vocabulary is a SKOS concept scheme for describing the nature of hazards associated with specific materials, with coverage spanning the biological and geological collections domains."@en;
    dcterms:description "The Hazard Type vocabulary is a SKOS concept scheme for describing the nature of hazards associated with specific materials, with coverage spanning the biological and geological collections domains."@en;
    dcterms:publisher "TDWG Mineralogy Extension Task Group"@en;
    dcterms:creator "TDWG Mineralogy Extension Task Group"@en;
    dcterms:contributor "TDWG Mineralogy Extension Task Group"@en;
    dcterms:provenance "Compiled by the TDWG Mineralogy Extension Task Group to support community use and the new term hazardType, released as part of a broader set of terms extending Darwin Core coverage to mineralogical and geological collections."@en;
    dcterms:created "2026-04-09"^^xsd:date;
    dcterms:modified "2026-04-09"^^xsd:date;
    dcat:version "2026-04-09";
    skos:scopeNote "Despite being published by the Mineralogy Extension Task Group, the hazard type concept scheme is intended to support specimens across that belong to biological and geological collections."@en;
    <http://purl.org/vocab/vann/usageNote> "Intended to be used in conjuncture with the proposed darwin core term, hazardType"@en;
    dcat:keyword "Collections"@en, "Geologic Collections"@en, "Specimens"@en, "Hazards"@en, "Biological Collections"@en;
    sdo:citation "Norton B, Walcott R, Burri T, Puschnig A, Dombrowski A, Greber N, Hints O, Mansur A, Ralph J, Richard S, Tacker C. Hazard Type Vocabulary (pending)."@en;
