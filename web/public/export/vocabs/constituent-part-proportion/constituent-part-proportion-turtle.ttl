<https://vocab.geospecimens.org/def/constituent-part-proportion> a skos:ConceptScheme;
    skos:prefLabel "Constituent Part Proportion"@en;
    dcterms:title "Constituent Part Proportion"@en;
    skos:definition "The Constituent Part Proportion vocabulary is a SKOS-based terminology for describing the presence of a constituent part within the context of a parent compound specimen. The scheme provides comprehensive coverage for describing qualitative abundance."@en;
    dcterms:description "The Constituent Part Proportion vocabulary is a SKOS-based terminology for describing the presence of a constituent part within the context of a parent compound specimen. The scheme provides comprehensive coverage for describing qualitative abundance."@en;
    dcterms:publisher _:b1_agent_mineralogy_extension_task_group;
    dcterms:creator _:b1_agent_mineralogy_extension_task_group;
    dcterms:contributor _:b1_agent_mineralogy_extension_task_group;
    dcterms:provenance "Compiled by the TDWG Mineralogy Extension Task Group for community use and to support the extension release by providing standardized values for Constituent Part proportions, which is key attribute of Constituent Parts of a Component Specimen"@en;
    dcterms:created "2026-04-17"^^xsd:date;
    dcterms:modified "2026-04-17"^^xsd:date;
    dcat:version "2026-04-17";
    skos:scopeNote "Values are valid within the scope of a material entity comprised of physically discrenable parts unified through physical attachment or some unifying criteria"@en;
    <http://purl.org/vocab/vann/usageNote> "Used together with Constituent Part Role to describe the nature of a Constituent Part within the context of its parent Compound Specimen."@en;
    skos:historyNote "Terms and definitions are largely derived from the CGI Vocabulary, Proportion Term (http://resource.geosciml.org/classifier/cgi/proportionterm), with modifications to suit the context of a curated collection of specimens at the hand-specimen level"@en;
    dcat:keyword "Collections"@en, "Geologic Collections"@en, "Specimens"@en, "Compound Specimen"@en, "Constituent Part"@en;
    sdo:citation "Norton B, Walcott R, Burri T, Puschnig A, Dombrowski A, Greber N, Hints O, Mansur A, Ralph J, Richard S, Tacker C. Constituent Part Proportion Vocabulary (pending)."@en;
    sdo:license <https://creativecommons.org/licenses/by/4.0/>;
    reg:derivationMode <https://linked.data.gov.au/def/vocdermods/subsetting-and-extension>;
    reg:status <https://linked.data.gov.au/def/reg-statuses/experimental>;
    skos:hasTopConcept <https://vocab.geospecimens.org/def/constituent-part-proportion/all>, <https://vocab.geospecimens.org/def/constituent-part-proportions/major>, <https://vocab.geospecimens.org/def/constituent-part-proportions/minor>, <https://vocab.geospecimens.org/def/constituent-part-proportions/rare>, <https://vocab.geospecimens.org/def/constituent-part-proportions/trace>, <https://vocab.geospecimens.org/def/constituent-part-proportions/present>, <https://vocab.geospecimens.org/def/constituent-part-proportions/variable>, <https://vocab.geospecimens.org/def/constituent-part-proportions/absent>;
    prov:qualifiedAttribution _:n3-49, _:n3-50.
