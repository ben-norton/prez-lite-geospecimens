  <rdf:Description rdf:about="https://vocab.geospecimens.org/def/constituent-part-proportion">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <skos:prefLabel xml:lang="en">Constituent Part Proportion</skos:prefLabel>
    <dcterms:title xml:lang="en">Constituent Part Proportion</dcterms:title>
    <skos:definition xml:lang="en">The Constituent Part Proportion vocabulary is a SKOS-based terminology for describing the presence of a constituent part within the context of a parent compound specimen. The scheme provides comprehensive coverage for describing qualitative abundance.</skos:definition>
    <dcterms:description xml:lang="en">The Constituent Part Proportion vocabulary is a SKOS-based terminology for describing the presence of a constituent part within the context of a parent compound specimen. The scheme provides comprehensive coverage for describing qualitative abundance.</dcterms:description>
    <dcterms:publisher rdf:nodeID="b1_agent_mineralogy_extension_task_group"/>
    <dcterms:creator rdf:nodeID="b1_agent_mineralogy_extension_task_group"/>
    <dcterms:contributor rdf:nodeID="b1_agent_mineralogy_extension_task_group"/>
    <dcterms:provenance xml:lang="en">Compiled by the TDWG Mineralogy Extension Task Group for community use and to support the extension release by providing standardized values for Constituent Part proportions, which is key attribute of Constituent Parts of a Component Specimen</dcterms:provenance>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</dcterms:created>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</dcterms:modified>
    <dcat:version>2026-04-17</dcat:version>
    <skos:scopeNote xml:lang="en">Values are valid within the scope of a material entity comprised of physically discrenable parts unified through physical attachment or some unifying criteria</skos:scopeNote>
    <http://purl.org/vocab/vann/usageNote xml:lang="en">Used together with Constituent Part Role to describe the nature of a Constituent Part within the context of its parent Compound Specimen.</http://purl.org/vocab/vann/usageNote>
    <skos:historyNote xml:lang="en">Terms and definitions are largely derived from the CGI Vocabulary, Proportion Term (http://resource.geosciml.org/classifier/cgi/proportionterm), with modifications to suit the context of a curated collection of specimens at the hand-specimen level</skos:historyNote>
