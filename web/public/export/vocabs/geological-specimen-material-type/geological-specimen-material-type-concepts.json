{"@context":{"iri":"@id","prefLabel":"http://www.w3.org/2004/02/skos/core#prefLabel","altLabels":"http://www.w3.org/2004/02/skos/core#altLabel","definition":"http://www.w3.org/2004/02/skos/core#definition","notation":"http://www.w3.org/2004/02/skos/core#notation","broader":"http://www.w3.org/2004/02/skos/core#broader","scheme":"http://www.w3.org/2004/02/skos/core#inScheme","schemeLabel":"https://prez.dev/schemeLabel"},"@graph":[{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/astromaterial","prefLabel":"Astromaterial","definition":"A geologic material that is extraterrestrial in origin or derived from a geological process involving an extraterrestrial material (impactite)","notation":"astromaterial","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/fossil","prefLabel":"Fossil","definition":"Any remains, trace, or imprint of a plant or animal preserved in the Earth's crust since some past geologic or prehistoric time; loosely, any evidence of past life.","notation":"fossil","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/gemstone","prefLabel":"Gemstone","altLabels":["Gem"],"definition":"Any mineral or naturally occurring substance that, when cut and polished, has sufficient beauty, rarity, and durability for use as a personal adornment or other ornament.","notation":"gemstone","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/mineral","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","prefLabel":"Geological Material","altLabels":["Geologic Material","Earth Material","Geological Specimen Type","Material Entity Type"],"definition":"A material entity comprised of a natural amount of matter generated by some geologic process, includes synthetic material intended to represent a geological material","notation":"geologicalMaterial","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/meteorite","prefLabel":"Meteorite","definition":"A natural, solid object, derived from a celestial body, that was transported by natural means from the body on which it formed to a region outside the dominant gravitational influence of that body and that later collided with a natural or artificial body larger than itself.","notation":"meteorite","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/astromaterial","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/mineral","prefLabel":"Mineral","definition":"A naturally occurring element or chemical compound of homogeneous composition, normally with a crystalline structure, and resulting from some geological process on Earth or in extraterrestrial bodies","notation":"mineral","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/ore","prefLabel":"Ore","altLabels":["Economic Mineral","Metallic Ore","Industrial Mineral","Mineral Deposit"],"definition":"A naturally occurring geological material from which economically valuable minerals can be extracted.","notation":"ore","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-material-type/rock","prefLabel":"Rock","definition":"Consolidated aggregate of one or more EarthMaterials, or a body of undifferentiated mineral matter, or of solid organic material. Includes mineral aggregates such as granite, shale, marble; glassy matter such as obsidian; and organic material such a coal. Excludes unconsolidated materials.","notation":"rock","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/rock-core","prefLabel":"Rock Core","definition":"A geological material, commonly cylindrical in shape, recovered from a borehole through drilling","notation":"rockCore","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/rock","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/sample-return","prefLabel":"Sample Return","definition":"Astromaterial returned from sample collection missions to celestial objects (e.g. comets, asteroids, the Moon, Mars)","notation":"sampleReturn","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/astromaterial","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/synthetic-mineral","prefLabel":"Synthetic Mineral","definition":"Man-made materials created in a laboratory that are intended to representative of natural occurring geological material","notation":"syntheticMineral","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/mineral","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/trace-fossil","prefLabel":"Trace Fossil","altLabels":["Ichnofossil"],"definition":"A sedimentary structure produced by the life activities (other than growth) of some organism","notation":"traceFossil","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/fossil","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"},{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/unconsolidated-material","prefLabel":"Unconsolidated Material","definition":"A geologic material composed of an aggregation of particles that do not adhere to each other strongly enough that the aggregate can be considered a solid in its own right.","notation":"unconsolidatedMaterial","broader":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type"}]}