present","prefLabel":"Present","altLabels":[],"notation":"present","definition":"A material component is confirmed to exist in the material entity but proportion has not been quantified","scheme":"https://vocab.geospecimens.org/def/constituent-part-proportion","schemeLabel":"Constituent Part Proportion","publisher":[]},"6":{"iri":"https://vocab.geospecimens.org/def/constituent-part-proportions/rare","prefLabel":"Rare","altLabels":[],"notation":"rare","definition":"A material component comprises between 0.1% and 5% of the material entity by volume","scheme":"https://vocab.geospecimens.org/def/constituent-part-proportion","schemeLabel":"Constituent Part Proportion","publisher":[]},"7":{"iri":"https://vocab.geospecimens.org/def/constituent-part-proportions/trace","prefLabel":"Trace","altLabels":[],"notation":"trace","definition":"A material component comprises less than 0.1% of the material entity by volume","scheme":"https://vocab.geospecimens.org/def/constituent-part-proportion","schemeLabel":"Constituent Part Proportion","publisher":[]},"8":{"iri":"https://vocab.geospecimens.org/def/constituent-part-proportions/variable","prefLabel":"Variable","altLabels":[],"notation":"variable","definition":"The proportion of a material component varies significantly within the material entity or across specimens","scheme":"https://vocab.geospecimens.org/def/constituent-part-proportion","schemeLabel":"Constituent Part Proportion","publisher":[]},"9":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/alternate-name","prefLabel":"Alternate Name","altLabels":[],"notation":"","definition":"A name by which a geologic material is frequently referred, without reference to any formal usage or structure nor sanctioned by an authoritative body","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"10":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/cataloged-name","prefLabel":"Cataloged Name","altLabels":[],"notation":"","definition":"The name of a geological material for cataloging or presentation purposes.","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"11":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/classification","prefLabel":"Classification","altLabels":["Species"],"notation":"","definition":"A name derived from an authoritative classification system at any rank","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"12":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/formal-name","prefLabel":"Formal Name","altLabels":["Official Name"],"notation":"","definition":"A name assigned by an authoritative body based on a defined set of unambiguous criteria and belonging to a formal nomenclature","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"13":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/group","prefLabel":"Group","altLabels":[],"notation":"","definition":"The name of a mineralogical group a specimen belongs to. Groups are defined as a set of mineral species with essentially the same crystal structure and composed of chemically similar elements.","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"14":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/historical","prefLabel":"Historical","altLabels":[],"notation":"","definition":"An alias of a mineral name used within a historical context or derived from a historical source","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"15":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/ima-approved-name","prefLabel":"IMA Approved Name","altLabels":[],"notation":"","definition":"A mineral name that has received formal approval by the International Mineralogical Association (IMA)","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"16":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/obsolete","prefLabel":"Obsolete","altLabels":[],"notation":"","definition":"A name defined in prior standards or classification systems but has since been removed from those authoritative sources. Includes names designated by the International Mineralogical Association as discredited or obsolete.","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"17":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/series","prefLabel":"Series","altLabels":["Solid Solution Series"],"notation":"","definition":"Name of the solid solution series to which a specimen belongs.","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"18":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/structural-group","prefLabel":"Structural Group","altLabels":[],"notation":"","definition":"A group name based on a shared crystal structure and composition of chemically similar elements","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"19":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/synonym","prefLabel":"Synonym","altLabels":[],"notation":"","definition":"An alias of a mineral species no longer recognized as the official classification","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"20":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/unapproved","prefLabel":"Unapproved","altLabels":[],"notation":"","definition":"The name of a mineralogical specimen that is pending approval as an offical name by the International Mineralogical Association (IMA)","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"21":{"iri":"https://vocab.geospecimens.org/def/geological-material-name-type/variety","prefLabel":"Variety","altLabels":[],"notation":"","definition":"A mineral that is a type of the mineral species, distinguished by color or other optical phenomenon or characteristic","scheme":"https://vocab.geospecimens.org/def/geological-material-name-type","schemeLabel":"Geological Material Name Type","publisher":[]},"22":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/astromaterial","prefLabel":"Astromaterial","altLabels":[],"notation":"astromaterial","definition":"A geologic material that is extraterrestrial in origin or derived from a geological process involving an extraterrestrial material (impactite)","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"23":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/fossil","prefLabel":"Fossil","altLabels":[],"notation":"fossil","definition":"Any remains, trace, or imprint of a plant or animal preserved in the Earth's crust since some past geologic or prehistoric time; loosely, any evidence of past life.","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"24":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/gemstone","prefLabel":"Gemstone","altLabels":["Gem"],"notation":"gemstone","definition":"Any mineral or naturally occurring substance that, when cut and polished, has sufficient beauty, rarity, and durability for use as a personal adornment or other ornament.","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"25":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/geological-material","prefLabel":"Geological Material","altLabels":["Geologic Material","Earth Material","Geological Specimen Type","Material Entity Type"],"notation":"geologicalMaterial","definition":"A material entity comprised of a natural amount of matter generated by some geologic process, includes synthetic material intended to represent a geological material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"26":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/meteorite","prefLabel":"Meteorite","altLabels":[],"notation":"meteorite","definition":"A natural, solid object, derived from a celestial body, that was transported by natural means from the body on which it formed to a region outside the dominant gravitational influence of that body and that later collided with a natural or artificial body larger than itself.","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"27":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/mineral","prefLabel":"Mineral","altLabels":[],"notation":"mineral","definition":"A naturally occurring element or chemical compound of homogeneous composition, normally with a crystalline structure, and resulting from some geological process on Earth or in extraterrestrial bodies","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"28":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/ore","prefLabel":"Ore","altLabels":["Economic Mineral","Metallic Ore","Industrial Mineral","Mineral Deposit"],"notation":"ore","definition":"A naturally occurring geological material from which economically valuable minerals can be extracted.","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"29":{"iri":"https://vocab.geospecimens.org/def/geological-material-type/rock","prefLabel":"Rock","altLabels":[],"notation":"rock","definition":"Consolidated aggregate of one or more EarthMaterials, or a body of undifferentiated mineral matter, or of solid organic material. Includes mineral aggregates such as granite, shale, marble; glassy matter such as obsidian; and organic material such a coal. Excludes unconsolidated materials.","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"30":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/rock-core","prefLabel":"Rock Core","altLabels":[],"notation":"rockCore","definition":"A geological material, commonly cylindrical in shape, recovered from a borehole through drilling","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"31":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/sample-return","prefLabel":"Sample Return","altLabels":[],"notation":"sampleReturn","definition":"Astromaterial returned from sample collection missions to celestial objects (e.g. comets, asteroids, the Moon, Mars)","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"32":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/synthetic-mineral","prefLabel":"Synthetic Mineral","altLabels":[],"notation":"syntheticMineral","definition":"Man-made materials created in a laboratory that are intended to representative of natural occurring geological material","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"33":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/trace-fossil","prefLabel":"Trace Fossil","altLabels":["Ichnofossil"],"notation":"traceFossil","definition":"A sedimentary structure produced by the life activities (other than growth) of some organism","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"34":{"iri":"https://vocab.geospecimens.org/def/geological-specimen-material-type/unconsolidated-material","prefLabel":"Unconsolidated Material","altLabels":[],"notation":"unconsolidatedMaterial","definition":"A geologic material composed of an aggregation of particles that do not adhere to each other strongly enough that the aggregate can be considered a solid in its own right.","scheme":"http://vocab.geospecimens.org/def/geological-specimen-type","schemeLabel":"Geological Specimen Material Type","publisher":[]},"35":{"iri":"https://vocab.geospecimens.org/def/hazard-type/asbestos-bearing","prefLabel":"Asbestos-bearing","altLabels":[],"notation":"asbestosBearing","definition":"A sample or specimen containing acicular or fibrous asbestos (serpentine or amphibole) minerals, either naturally or as part of storage materials, which can cause internal damage if breathed or ingested.","scheme":"http://vocab.geospecimens.org/def/hazard-type","schemeLabel":"Hazard Types","publisher":[]},"36":{"iri":"https://vocab.geospecimens.org/def/hazard-type/carcinogen","prefLabel":"Carcinogen","altLabels":[],"notation":"carcinogen","definition":"A role played by a chemical compound which is known to induce a process of carcinogenesis by corrupting normal cellular pathways, leading