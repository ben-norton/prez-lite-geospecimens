@prefix cpp:         <http://vocab.geospecimens.org/def/constituent-part-proportion> .
@prefix cpps:        <http://vocab.geospecimens.org/def/constituent-part-proportions> .
@prefix skosxl:      <http://www.w3.org/2008/05/skos-xl#> .
@prefix isothes:     <http://purl.org/iso25964/skos-thes#> .
